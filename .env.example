# miniClima EBC10 — environment config
# Change HOST once to switch between local dev and deployment target (e.g. ben.local)

HOST=localhost

# Serial port the EBC10 is connected to
# Linux/Pi: /dev/ttyACM0 (CH34x USB adapter) or /dev/ttyUSB0
# macOS:    /dev/cu.usbserial-XXXX
# Windows:  COM3
EBC10_PORT=/dev/ttyACM0

# Serial baud rate — EBC10 is always 9600
EBC10_BAUD=9600

# Service ports
API_PORT=8000
FRONTEND_PORT=3000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002

# Log level for the API and ebc10 serial client (DEBUG shows raw serial traffic)
LOG_LEVEL=INFO

# Derived URLs (NEXT_PUBLIC_* and CORS_ORIGINS) are constructed from HOST + ports
# in justfile and docker-compose.yml — do not set them here

CUTOFF_DAYS=60