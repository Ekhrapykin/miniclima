# miniClima EBC10 — API server environment

# Serial port the EBC10 is connected to
# Linux/Pi: /dev/ttyACM0 (CH34x USB adapter) or /dev/ttyUSB0
# macOS:    /dev/cu.usbserial-XXXX
# Windows:  COM3
EBC10_PORT=/dev/ttyACM0

# Serial baud rate — EBC10 is always 9600
EBC10_BAUD=9600

# API server port
API_PORT=8000

# Frontend dev server port
FRONTEND_PORT=3000

# Frontend — Next.js API base URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# API — allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000
