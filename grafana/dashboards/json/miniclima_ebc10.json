{
  "id": null,
  "uid": "ebc10",
  "title": "miniClima EBC10",
  "tags": ["ebc10", "humidity"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Humidity & Temperature",
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "ebc10_humidity_percent",
          "legendFormat": "Humidity",
          "refId": "A"
        },
        {
          "expr": "ebc10_setpoint_percent",
          "legendFormat": "Setpoint",
          "refId": "B"
        },
        {
          "expr": "ebc10_humidity_lo",
          "legendFormat": "Alarm Min",
          "refId": "C"
        },
        {
          "expr": "ebc10_humidity_hi",
          "legendFormat": "Alarm Max",
          "refId": "D"
        },
        {
          "expr": "ebc10_temperature_celsius{sensor=\"t1\"}",
          "legendFormat": "T1 (cold)",
          "refId": "E"
        },
        {
          "expr": "ebc10_temperature_celsius{sensor=\"t2\"}",
          "legendFormat": "T2 (hot)",
          "refId": "F"
        },
        {
          "expr": "ebc10_temperature_celsius{sensor=\"t_out\"}",
          "legendFormat": "T Ambient",
          "refId": "G"
        },
        {
          "expr": "ebc10_pump_running",
          "legendFormat": "Pump",
          "refId": "H"
        },
        {
          "expr": "ebc10_alarm_event",
          "legendFormat": "Alarm",
          "refId": "I"
        },
        {
          "expr": "ebc10_error_event",
          "legendFormat": "Error",
          "refId": "J"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 2, "axisSoftMin": 0, "axisSoftMax": 100 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Setpoint" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Alarm Min" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Alarm Max" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "T1 (cold)" },
            "properties": [
              { "id": "unit", "value": "celsius" },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "light-blue" } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "min", "value": null },
              { "id": "max", "value": null }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "T2 (hot)" },
            "properties": [
              { "id": "unit", "value": "celsius" },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "semi-dark-red" } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "min", "value": null },
              { "id": "max", "value": null }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "T Ambient" },
            "properties": [
              { "id": "unit", "value": "celsius" },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.lineStyle", "value": { "dash": [6, 3], "fill": "dash" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "light-purple" } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "min", "value": null },
              { "id": "max", "value": null }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Pump" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "custom.axisPlacement", "value": "hidden" },
              { "id": "custom.lineWidth", "value": 0 },
              { "id": "custom.fillOpacity", "value": 15 },
              { "id": "custom.lineInterpolation", "value": "stepAfter" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Alarm" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "custom.axisPlacement", "value": "hidden" },
              { "id": "custom.lineWidth", "value": 0 },
              { "id": "custom.pointSize", "value": 8 },
              { "id": "custom.showPoints", "value": "always" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } },
              { "id": "min", "value": null },
              { "id": "max", "value": null }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Error" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "custom.axisPlacement", "value": "hidden" },
              { "id": "custom.lineWidth", "value": 0 },
              { "id": "custom.pointSize", "value": 8 },
              { "id": "custom.showPoints", "value": "always" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "dark-red" } },
              { "id": "min", "value": null },
              { "id": "max", "value": null }
            ]
          }
        ]
      },
      "gridPos": { "x": 0, "y": 0, "w": 16, "h": 8 }
    },
    {
      "type": "stat",
      "title": "Current Humidity",
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "ebc10_humidity_percent{job=\"ebc10-api\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 35 },
              { "color": "red", "value": 75 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 }
    },
    {
      "type": "stat",
      "title": "Device State",
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "ebc10_device_running{job=\"ebc10-api\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Stand by", "color": "orange" }, "1": { "text": "Running", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto" },
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 }
    },
    {
      "type": "stat",
      "title": "Operating Hours",
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "ebc10_operating_hours", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "h" }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "auto" },
      "gridPos": { "x": 16, "y": 4, "w": 4, "h": 4 }
    },
    {
      "type": "stat",
      "title": "Setpoint",
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "ebc10_setpoint_percent{job=\"ebc10-api\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "auto" },
      "gridPos": { "x": 20, "y": 4, "w": 4, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Poll Errors",
      "id": 7,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "increase(ebc10_poll_errors_total[5m])", "legendFormat": "Errors (5m)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    }
  ]
}
