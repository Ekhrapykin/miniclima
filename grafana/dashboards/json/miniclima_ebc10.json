{
  "id": null,
  "uid": "ebc10",
  "title": "miniClima EBC10",
  "tags": ["ebc10", "humidity"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Humidity (%RH)",
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "ebc10_humidity_percent",
          "legendFormat": "Humidity",
          "refId": "A"
        },
        {
          "expr": "ebc10_setpoint_percent",
          "legendFormat": "Setpoint",
          "refId": "B"
        },
        {
          "expr": "ebc10_humidity_lo",
          "legendFormat": "Alarm Min",
          "refId": "C"
        },
        {
          "expr": "ebc10_humidity_hi",
          "legendFormat": "Alarm Max",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Setpoint" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Alarm Min" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Alarm Max" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          }
        ]
      },
      "gridPos": { "x": 0, "y": 0, "w": 16, "h": 8 }
    },
    {
      "type": "stat",
      "title": "Current Humidity",
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "ebc10_humidity_percent{job=\"ebc10-api\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 35 },
              { "color": "red", "value": 75 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 }
    },
    {
      "type": "stat",
      "title": "Device State",
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "ebc10_device_running{job=\"ebc10-api\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Stand by", "color": "orange" }, "1": { "text": "Running", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto" },
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 }
    },
    {
      "type": "stat",
      "title": "Operating Hours",
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "ebc10_operating_hours", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "h" }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "auto" },
      "gridPos": { "x": 16, "y": 4, "w": 4, "h": 4 }
    },
    {
      "type": "stat",
      "title": "Setpoint",
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "ebc10_setpoint_percent{job=\"ebc10-api\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "auto" },
      "gridPos": { "x": 20, "y": 4, "w": 4, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Temperature (°C)",
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "ebc10_temperature_celsius{sensor=\"t1\"}", "legendFormat": "T1 (cold side)", "refId": "A" },
        { "expr": "ebc10_temperature_celsius{sensor=\"t2\"}", "legendFormat": "T2 (hot side)", "refId": "B" },
        { "expr": "ebc10_temperature_celsius{sensor=\"t_out\"}", "legendFormat": "T Outer", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "celsius", "custom": { "lineWidth": 2 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "T Outer" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [6, 3], "fill": "dash" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "light-purple" } }
            ]
          }
        ]
      },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Poll Errors",
      "id": 7,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "increase(ebc10_poll_errors_total[5m])", "legendFormat": "Errors (5m)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Pump Activity",
      "id": 8,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "ebc10_pump_running", "legendFormat": "Pump", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 40,
            "lineInterpolation": "stepAfter"
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Off" }, "1": { "text": "On" } } }
          ],
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Events (Alarm / Error)",
      "id": 9,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "ebc10_alarm_event", "legendFormat": "Alarm", "refId": "A" },
        { "expr": "ebc10_error_event", "legendFormat": "Error", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "lineWidth": 0,
            "pointSize": 10,
            "showPoints": "always",
            "fillOpacity": 0
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Alarm" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Error" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 6 }
    }
  ]
}
